{
  "name": "datechain",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@8.11.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "gen:openapi": "pnpm --filter @datechain/api openapi:generate",
    "gen:types": "pnpm gen:openapi && pnpm --filter @datechain/api-client gen:types",
    "seed": "pnpm --filter @datechain/api seed",
    "reset": "pnpm --filter @datechain/api reset"
  },
  "devDependencies": {
    "@datechain/config": "workspace:*",
    "prettier": "^3.2.5",
    "turbo": "^1.13.0",
    "typescript": "^5.4.5"
  }
}
