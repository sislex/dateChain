  "info": {
    "title": "dateChain API",
    "description": "REST API for the dateChain dating platform",
    "version": "0.1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "access-token": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "RequestOtpDto": {
        "type": "object",
        "properties": {
          "channel": {
            "type": "string",
            "enum": [
              "phone",
              "email"
            ]
          },
          "identifier": {
            "type": "string",
            "example": "+15551234567",
            "description": "Phone (E.164) or email"
          }
        },
        "required": [
          "channel",
          "identifier"
        ]
      },
      "VerifyOtpDto": {
        "type": "object",
        "properties": {
          "channel": {
            "type": "string",
            "enum": [
              "phone",
              "email"
            ]
          },
          "identifier": {
            "type": "string"
          },
          "code": {
            "type": "string",
            "example": "123456"
          }
        },
        "required": [
          "channel",
          "identifier",
          "code"
        ]
      },
      "RefreshDto": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string"
          }
        },
        "required": [
          "refreshToken"
        ]
      },
      "AdminLoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "totp": {
            "type": "string",
            "description": "TOTP code, required if 2FA is enabled"
          }
        },
        "required": [
          "email",
          "password"
        ]
      }
    }
  }
}
