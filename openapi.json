        "type": "http"
      }
    },
    "schemas": {
      "RequestOtpDto": {
        "type": "object",
        "properties": {
          "channel": {
            "type": "string",
            "enum": [
              "phone",
              "email"
            ]
          },
          "identifier": {
            "type": "string",
            "example": "+15551234567",
            "description": "Phone (E.164) or email"
          }
        },
        "required": [
          "channel",
          "identifier"
        ]
      },
      "VerifyOtpDto": {
        "type": "object",
        "properties": {
          "channel": {
            "type": "string",
            "enum": [
              "phone",
              "email"
            ]
          },
          "identifier": {
