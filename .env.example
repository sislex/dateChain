# ─── Database (Postgres + PostGIS) ───────────────────────────────
POSTGRES_USER=datechain
POSTGRES_PASSWORD=datechain
POSTGRES_DB=datechain
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# ─── Redis ───────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_HOST=localhost

# ─── API ─────────────────────────────────────────────────────────
API_PORT=3000
NODE_ENV=development

# ─── Auth / JWT ──────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
OTP_TTL_SECONDS=300
# DEV ONLY: accept any OTP code (phone-only login). Never enable in production.
AUTH_DEV_LOGIN=false

# ─── Media (local disk storage) ──────────────────────────────────
MEDIA_STORAGE_DIR=./uploads
MEDIA_MAX_FILE_SIZE_MB=10

# ─── Feature flags (core clone: monetization off) ────────────────
FEATURE_MONETIZATION=false
FEATURE_BOOST=false
FEATURE_PASSPORT=false

# ─── Blockchain (crypto escrow dates) ────────────────────────────
# Local Hardhat now; point these at a real network later.
CHAIN_RPC_URL=http://127.0.0.1:8545
CHAIN_ID=31337
# Hardhat account #0 (owner/treasury) — mints DATE and funds custodial wallets.
TREASURY_PRIVKEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
# 32-byte hex key encrypting custodial private keys (DEV ONLY — rotate for real use).
WALLET_ENC_KEY=0x000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f
# Demo funding for each new custodial wallet.
WALLET_SEED_AMOUNT=1000
WALLET_GAS_ETH=1
# Path to the contracts deployment file (addresses + ABIs), relative to apps/api.
CONTRACTS_DEPLOYMENTS=../../packages/contracts/deployments/localhost.json
