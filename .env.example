# ─── Database (Postgres + PostGIS) ───────────────────────────────
POSTGRES_USER=datechain
POSTGRES_PASSWORD=datechain
POSTGRES_DB=datechain
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# ─── Redis ───────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_HOST=localhost

# ─── API ─────────────────────────────────────────────────────────
API_PORT=3000
NODE_ENV=development

# ─── Auth / JWT ──────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ─── Media (local disk storage) ──────────────────────────────────
MEDIA_STORAGE_DIR=./uploads
MEDIA_MAX_FILE_SIZE_MB=10

# ─── Feature flags (core clone: monetization off) ────────────────
FEATURE_MONETIZATION=false
FEATURE_BOOST=false
FEATURE_PASSPORT=false
